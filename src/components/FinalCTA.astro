<style>
  .cta {
    position: relative;
    background: var(--dark);
    padding: 96px 0;
    overflow: hidden;
  }

  .cta__glow {
    position: absolute;
    top: -150px;
    right: -150px;
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, rgba(240, 78, 26, 0.12) 0%, transparent 70%);
    pointer-events: none;
  }

  .cta__inner {
    text-align: center;
    position: relative;
    z-index: 1;
  }

  .cta__title {
    margin-bottom: 16px;
  }

  .cta__subtitle {
    margin: 0 auto 32px;
  }

  .cta__buttons {
    display: flex;
    justify-content: center;
    gap: 16px;
    flex-wrap: wrap;
  }

  .cta__pulse {
    animation: ctaPulse 2s ease-in-out infinite;
  }

  @keyframes ctaPulse {
    0%, 100% { box-shadow: 0 0 0 0 rgba(240, 78, 26, 0.4); }
    50% { box-shadow: 0 0 0 12px rgba(240, 78, 26, 0); }
  }

  @media (max-width: 480px) {
    .cta__buttons { flex-direction: column; align-items: stretch; }
    .cta__buttons .btn { justify-content: center; }
    .cta { padding: 64px 0; }
  }
</style>
