---
import { t, type Locale } from '../i18n/utils';

interface Props {
  locale?: Locale;
}

const { locale = 'ro' } = Astro.props;
---
<div class="floating-cta" id="floatingCta">
  <a href="#contacteaza-ne" class="floating-cta__btn" aria-label={t(locale, 'floating.aria')}>
    <span class="floating-cta__ring"></span>
    <span class="floating-cta__icon">
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
    </span>
  </a>
  <div class="floating-cta__tooltip">
    <p class="floating-cta__text"><strong>{t(locale, 'floating.title')}</strong></p>
    <p class="floating-cta__sub">{t(locale, 'floating.desc')}</p>
  </div>
</div>

<style>
  .floating-cta {
    position: fixed;
    bottom: 32px;
    right: 28px;
    z-index: 800;
    display: flex;
    align-items: center;
    gap: 0;
  }

  .floating-cta__btn {
    position: relative;
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: var(--orange);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--white);
    box-shadow: 0 4px 20px rgba(240, 78, 26, 0.5);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    flex-shrink: 0;
  }

  .floating-cta__btn:hover {
    transform: scale(1.1);
    box-shadow: 0 6px 30px rgba(240, 78, 26, 0.65);
  }

  .floating-cta__icon {
    position: relative;
    z-index: 2;
    display: flex;
    animation: phoneBounce 2s ease-in-out infinite;
  }

  .floating-cta__ring {
    position: absolute;
    inset: -4px;
    border-radius: 50%;
    border: 2px solid var(--orange);
    animation: ringPulse 2s ease-out infinite;
  }

  /* Tooltip */
  .floating-cta__tooltip {
    position: absolute;
    right: 76px;
    bottom: 4px;
    width: 260px;
    background: var(--white);
    border-radius: 14px;
    padding: 16px 18px;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.18);
    opacity: 0;
    transform: translateX(10px);
    pointer-events: none;
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  .floating-cta__tooltip::after {
    content: '';
    position: absolute;
    right: -8px;
    bottom: 22px;
    width: 16px;
    height: 16px;
    background: var(--white);
    border-radius: 3px;
    transform: rotate(45deg);
    box-shadow: 4px -4px 8px rgba(0, 0, 0, 0.05);
  }

  .floating-cta:hover .floating-cta__tooltip {
    opacity: 1;
    transform: translateX(0);
    pointer-events: auto;
  }

  .floating-cta__text {
    font-family: var(--font-heading);
    font-size: 0.95rem;
    font-weight: 800;
    color: var(--dark);
    margin-bottom: 4px;
    line-height: 1.3;
  }

  .floating-cta__sub {
    font-size: 0.82rem;
    color: var(--gray-text);
    line-height: 1.5;
  }

  @keyframes ringPulse {
    0% { opacity: 0.8; transform: scale(1); }
    70% { opacity: 0; transform: scale(1.5); }
    100% { opacity: 0; transform: scale(1.5); }
  }

  @keyframes phoneBounce {
    0%, 100% { transform: rotate(0deg); }
    10% { transform: rotate(-12deg); }
    20% { transform: rotate(12deg); }
    30% { transform: rotate(-8deg); }
    40% { transform: rotate(0deg); }
  }

  @media (max-width: 900px) {
    .floating-cta {
      bottom: 80px;
      right: 16px;
    }

    .floating-cta__btn {
      width: 54px;
      height: 54px;
    }

    .floating-cta__btn svg {
      width: 24px;
      height: 24px;
    }

    .floating-cta__tooltip {
      display: none;
    }
  }
</style>
