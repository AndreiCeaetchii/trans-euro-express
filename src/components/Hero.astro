  </div>
  <div class="hero__divider"></div>
</section>

<style>
  .hero {
    position: relative;
    background: var(--black);
    padding: 140px 0 100px;
    overflow: hidden;
  }

  .hero__glow {
    position: absolute;
    top: -200px;
    right: -200px;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(240, 78, 26, 0.15) 0%, transparent 70%);
    pointer-events: none;
  }

  .hero__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: center;
  }

  .hero__badge {
    margin-bottom: 20px;
  }

  .hero__title {
    font-family: var(--font-heading);
    font-size: clamp(2.5rem, 5.5vw, 4rem);
    font-weight: 900;
    line-height: 1.05;
    color: var(--white);
    margin-bottom: 24px;
  }

  .hero__line {
    display: block;
  }

  .hero__line--1 { animation: fadeUp 0.6s ease both; }
  .hero__line--2 { animation: fadeUp 0.6s ease 0.15s both; }
  .hero__line--3 { animation: fadeUp 0.6s ease 0.3s both; font-size: 0.55em; color: rgba(255,255,255,0.6); margin-top: 8px; }

  .hero__accent {
    color: var(--orange);
  }

  .hero__subtitle {
    font-size: 1.15rem;
    color: rgba(255, 255, 255, 0.7);
    line-height: 1.7;
    max-width: 500px;
    margin-bottom: 32px;
  }

  .hero__ctas {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }

  .hero__map {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .hero__svg {
    width: 100%;
    max-width: 520px;
    height: auto;
  }

  .hero__country {
    animation: drawPath 2s ease forwards;
  }

  .hero__pulse {
    animation: pulse 2.5s ease-in-out infinite;
  }

  .hero__divider {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 60px;
    background: var(--white);
    clip-path: polygon(0 100%, 100% 100%, 100% 0);
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; r: inherit; }
    50% { opacity: 0; r: 14; }
  }

  @keyframes drawPath {
    from { stroke-dashoffset: 2000; stroke-dasharray: 2000; }
    to { stroke-dashoffset: 0; stroke-dasharray: 2000; }
  }

  @media (max-width: 900px) {
    .hero { padding: 110px 0 70px; }
    .hero__grid {
      grid-template-columns: 1fr;
      gap: 32px;
      text-align: center;
    }
    .hero__subtitle { margin-left: auto; margin-right: auto; }
    .hero__ctas { justify-content: center; }
    .hero__map { order: 2; margin-top: 16px; }
  }

  @media (max-width: 480px) {
    .hero { padding: 100px 0 60px; }
    .hero__title { font-size: clamp(2rem, 8vw, 2.8rem); }
    .hero__subtitle { font-size: 1rem; }
    .hero__ctas { flex-direction: column; align-items: stretch; }
    .hero__ctas .btn { justify-content: center; }
  }
</style>
