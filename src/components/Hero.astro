---
import { t, type Locale } from '../i18n/utils';

interface Props {
  locale?: Locale;
}

const { locale = 'ro' } = Astro.props;
---
<section class="hero" id="hero">
  <div class="hero__glow"></div>
  <div class="container hero__grid">
    <div class="hero__content">
      <span class="section-badge hero__badge reveal"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline;vertical-align:-3px"><circle cx="12" cy="12" r="10"/><path d="m16 10-4 4-4-4"/></svg> {t(locale, 'hero.badge')}</span>
      <h1 class="hero__title reveal">
        <span class="hero__line hero__line--1">{t(locale, 'hero.titleLine1')}</span>
        <span class="hero__line hero__line--2">{t(locale, 'hero.titleLine2Prefix')}<span class="hero__accent">{t(locale, 'hero.titleLine2Accent')}</span></span>
      </h1>
      <div class="hero__route-bar reveal">
        <span class="hero__route-dot"></span>
        <span class="hero__route-label">{t(locale, 'hero.routeMoldova')}</span>
        <span class="hero__route-line"></span>
        <span class="hero__route-dot"></span>
        <span class="hero__route-label">{t(locale, 'hero.routeRomania')}</span>
        <span class="hero__route-line"></span>
        <span class="hero__route-dot"></span>
        <span class="hero__route-label">{t(locale, 'hero.routeOdessa')}</span>
      </div>
      <p class="hero__subtitle reveal">
        {t(locale, 'hero.subtitle')}
      </p>
      <div class="hero__ctas reveal">
        <a href="tel:+37368860200" class="btn btn--orange">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
