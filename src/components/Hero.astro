          <text x="260" y="142" fill="rgba(255,255,255,0.6)" font-size="7" text-anchor="middle" font-family="var(--font-body)">Iași</text>
        </g>
        <g class="hero__pin-group">
          <circle cx="150" cy="260" r="3" fill="var(--orange)"/>
          <text x="150" y="254" fill="rgba(255,255,255,0.5)" font-size="7" text-anchor="middle" font-family="var(--font-body)">Craiova</text>
        </g>
