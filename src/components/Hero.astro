        </g>
        <g class="hero__pin-group">
          <circle cx="357" cy="210" r="2.5" fill="var(--orange)"/>
          <text x="343" y="217" fill="rgba(255,255,255,0.5)" font-size="7" text-anchor="end" font-family="var(--font-body)">Comrat</text>
        </g>
        <g class="hero__pin-group">
          <circle cx="375" cy="135" r="2.5" fill="var(--orange)"/>
          <text x="390" y="138" fill="rgba(255,255,255,0.5)" font-size="7" text-anchor="start" font-family="var(--font-body)">Soroca</text>
        </g>
        <g class="hero__pin-group">
          <circle cx="345" cy="145" r="2.5" fill="var(--orange)"/>
          <text x="330" y="148" fill="rgba(255,255,255,0.5)" font-size="7" text-anchor="end" font-family="var(--font-body)">Orhei</text>
        </g>

        <!-- Odessa pin -->
        <g class="hero__pin-group">
          <circle cx="455" cy="140" r="4.5" fill="var(--orange)"/><circle cx="455" cy="140" r="4.5" fill="var(--orange)" class="hero__pulse"/>
          <text x="455" y="158" fill="white" font-size="9" text-anchor="middle" font-family="var(--font-body)">Odessa</text>
        </g>
