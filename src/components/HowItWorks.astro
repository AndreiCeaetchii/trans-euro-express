---
import { t, type Locale } from '../i18n/utils';

interface Props {
  locale?: Locale;
}

const { locale = 'ro' } = Astro.props;

const steps = [
  { num: '01', title: t(locale, 'how.step1.title'), desc: t(locale, 'how.step1.desc'), icon: '📞' },
  { num: '02', title: t(locale, 'how.step2.title'), desc: t(locale, 'how.step2.desc'), icon: '📅' },
  { num: '03', title: t(locale, 'how.step3.title'), desc: t(locale, 'how.step3.desc'), icon: '🚛' },
  { num: '04', title: t(locale, 'how.step4.title'), desc: t(locale, 'how.step4.desc'), icon: '✅' },
];
---
<section class="how" id="cum-functioneaza">
  <div class="container">
    <div class="how__header reveal">
      <span class="section-badge">{t(locale, 'how.badge')}</span>
      <h2 class="section-title">{t(locale, 'how.title')}</h2>
      <p class="section-subtitle">{t(locale, 'how.subtitle')}</p>
    </div>
    <div class="how__grid">
      {steps.map((step, i) => (
        <div class="how__step reveal" style={`transition-delay: ${i * 0.1}s`}>
          <span class="how__icon">{step.icon}</span>
          <span class="how__num">{step.num}</span>
          <h3 class="how__step-title">{step.title}</h3>
          <p class="how__step-desc">{step.desc}</p>
          {i < 3 && <div class="how__connector" />}
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .how {
    background: var(--white);
    padding: 96px 0;
  }

  .how__header {
    text-align: center;
    margin-bottom: 64px;
  }

  .how__header .section-subtitle {
    margin: 0 auto;
  }

  .how__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 32px;
    position: relative;
  }

  .how__step {
    text-align: center;
    position: relative;
    padding: 32px 16px;
  }

  .how__icon {
    font-size: 2.5rem;
    display: block;
    margin-bottom: 12px;
  }

  .how__num {
    display: inline-block;
    font-family: var(--font-heading);
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--orange);
    background: rgba(240, 78, 26, 0.1);
    padding: 4px 12px;
    border-radius: 50px;
    margin-bottom: 12px;
  }

  .how__step-title {
    font-family: var(--font-heading);
    font-size: 1.2rem;
    font-weight: 800;
    color: var(--dark);
    margin-bottom: 8px;
  }

  .how__step-desc {
    font-size: 0.9rem;
    color: var(--gray-text);
    line-height: 1.6;
  }

  .how__connector {
    display: none;
  }

  @media (min-width: 901px) {
    .how__connector {
      display: block;
      position: absolute;
      top: 50%;
      right: -20px;
      width: 40px;
      height: 2px;
      background: linear-gradient(to right, var(--orange), transparent);
    }
  }

  @media (max-width: 900px) {
    .how__grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 480px) {
    .how__grid { grid-template-columns: 1fr; }
    .how { padding: 64px 0; }
  }
</style>
