---
import type { Locale } from '../i18n/utils';

interface Props {
  locale?: Locale;
}

const { locale = 'ro' } = Astro.props;
const base = import.meta.env.BASE_URL;

const locales = [
  { code: 'ro', label: 'RO', href: base },
  { code: 'en', label: 'EN', href: `${base}/en` },
  { code: 'ru', label: 'RU', href: `${base}/ru` },
] as const;

const currentLabel = locales.find(l => l.code === locale)?.label ?? 'RO';
const otherLocales = locales.filter(l => l.code !== locale);
---
<div class="lang-switch">
  <button class="lang-switch__current" aria-expanded="false" aria-haspopup="true">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline;vertical-align:-2px"><circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
    {currentLabel}
    <svg class="lang-switch__chevron" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
  </button>
  <div class="lang-switch__dropdown">
    {otherLocales.map((l) => (
      <a href={l.href} class="lang-switch__option">{l.label}</a>
    ))}
  </div>
</div>

<style is:global>
  .lang-switch {
    position: relative;
    z-index: 1002;
  }

  .lang-switch__current {
    display: flex;
    align-items: center;
    gap: 5px;
    font-family: var(--font-heading);
    font-size: 0.8rem;
    font-weight: 700;
    color: rgba(255, 255, 255, 0.75);
    padding: 6px 12px;
    border-radius: 6px;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.1);
    cursor: pointer;
    transition: color 0.2s ease, background 0.2s ease;
    letter-spacing: 0.5px;
  }

  .lang-switch__current:hover {
    color: var(--white);
    background: rgba(255, 255, 255, 0.12);
  }

  .lang-switch__chevron {
    transition: transform 0.2s ease;
  }

  .lang-switch.open .lang-switch__chevron {
    transform: rotate(180deg);
  }

  .lang-switch__dropdown {
    display: none;
    position: absolute;
    top: calc(100% + 6px);
    right: 0;
    min-width: 100%;
    background: rgba(10, 15, 24, 0.95);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 6px;
    padding: 4px;
    z-index: 1002;
  }

  .lang-switch.open .lang-switch__dropdown {
    display: block;
  }

  .lang-switch__option {
    display: block;
    font-family: var(--font-heading);
    font-size: 0.8rem;
    font-weight: 700;
    color: rgba(255, 255, 255, 0.6);
    padding: 6px 12px;
    border-radius: 4px;
    transition: color 0.2s ease, background 0.2s ease;
    letter-spacing: 0.5px;
    text-align: center;
    text-decoration: none;
  }

  .lang-switch__option:hover {
    color: var(--white);
    background: rgba(240, 78, 26, 0.2);
  }
</style>

<script>
  document.querySelectorAll('.lang-switch').forEach(sw => {
    const btn = sw.querySelector('.lang-switch__current');
    if (!btn) return;

    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      const isOpen = sw.classList.contains('open');
      document.querySelectorAll('.lang-switch.open').forEach(s => s.classList.remove('open'));
      if (!isOpen) sw.classList.add('open');
      btn.setAttribute('aria-expanded', String(!isOpen));
    });
  });

  document.addEventListener('click', () => {
    document.querySelectorAll('.lang-switch.open').forEach(s => {
      s.classList.remove('open');
      const btn = s.querySelector('.lang-switch__current');
      if (btn) btn.setAttribute('aria-expanded', 'false');
    });
  });
</script>
