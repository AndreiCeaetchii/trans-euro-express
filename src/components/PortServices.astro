---
import { t, type Locale } from '../i18n/utils';

interface Props {
  locale?: Locale;
}

const { locale = 'ro' } = Astro.props;
---
<section class="ports">
  <div class="container">
    <div class="ports__header reveal">
      <span class="section-badge">{t(locale, 'ports.badge')}</span>
      <h2 class="section-title section-title--light">{t(locale, 'ports.title')}</h2>
      <p class="section-subtitle section-subtitle--light">{t(locale, 'ports.subtitle')}</p>
    </div>

    <div class="ports__grid">
      <div class="ports__card ports__card--ro reveal">
        <div class="ports__card-top">
          <div class="ports__flag">
            <span class="ports__flag-stripe ports__flag-stripe--blue"></span>
            <span class="ports__flag-stripe ports__flag-stripe--yellow"></span>
            <span class="ports__flag-stripe ports__flag-stripe--red"></span>
          </div>
          <h3 class="ports__title">{t(locale, 'ports.constanta.title')}</h3>
          <p class="ports__desc">{t(locale, 'ports.constanta.desc')}</p>
        </div>
        <ul class="ports__list">
          <li><span class="ports__list-icon">🚢</span><span>{t(locale, 'ports.constanta.feat1')}</span></li>
          <li><span class="ports__list-icon">📋</span><span>{t(locale, 'ports.constanta.feat2')}</span></li>
          <li><span class="ports__list-icon">🛡️</span><span>{t(locale, 'ports.constanta.feat3')}</span></li>
          <li><span class="ports__list-icon">🚛</span><span>{t(locale, 'ports.constanta.feat4')}</span></li>
        </ul>
      </div>
      <div class="ports__card ports__card--ua reveal">
        <div class="ports__card-top">
          <div class="ports__flag">
            <span class="ports__flag-stripe ports__flag-stripe--ua-blue"></span>
            <span class="ports__flag-stripe ports__flag-stripe--ua-yellow"></span>
          </div>
          <h3 class="ports__title">{t(locale, 'ports.odessa.title')}</h3>
          <p class="ports__desc">{t(locale, 'ports.odessa.desc')}</p>
        </div>
        <ul class="ports__list">
          <li><span class="ports__list-icon">🚢</span><span>{t(locale, 'ports.odessa.feat1')}</span></li>
          <li><span class="ports__list-icon">📋</span><span>{t(locale, 'ports.odessa.feat2')}</span></li>
          <li><span class="ports__list-icon">🛡️</span><span>{t(locale, 'ports.odessa.feat3')}</span></li>
          <li><span class="ports__list-icon">🚛</span><span>{t(locale, 'ports.odessa.feat4')}</span></li>
        </ul>
      </div>
    </div>
  </div>
</section>

<style>
  .ports {
    background: var(--black);
    padding: 96px 0;
  }

  .ports__header {
    text-align: center;
    margin-bottom: 48px;
  }

  .ports__header .section-subtitle--light {
    margin: 0 auto;
  }

  .ports__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 32px;
  }

  .ports__card {
    position: relative;
    background: rgba(255, 255, 255, 0.07);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 16px;
    padding: 0;
    overflow: hidden;
    transition: transform 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
  }

  .ports__card:hover {
    transform: translateY(-4px);
    border-color: var(--orange);
    box-shadow: 0 12px 40px rgba(240, 78, 26, 0.1);
  }

  .ports__card-top {
    padding: 32px 28px 24px;
  }

  .ports__flag {
    display: flex;
    width: 100%;
    height: 4px;
    border-radius: 16px 16px 0 0;
    overflow: hidden;
    position: absolute;
    top: 0;
    left: 0;
  }

  .ports__flag-stripe { flex: 1; }
  .ports__flag-stripe--blue { background: #002B7F; }
  .ports__flag-stripe--yellow { background: #FCD116; }
  .ports__flag-stripe--red { background: #CE1126; }
  .ports__flag-stripe--ua-blue { background: #0057B7; }
  .ports__flag-stripe--ua-yellow { background: #FFD700; }

  .ports__title {
    font-family: var(--font-heading);
    font-size: 1.4rem;
    font-weight: 800;
    color: var(--white);
    margin-bottom: 10px;
  }

  .ports__desc {
    color: rgba(255, 255, 255, 0.65);
    font-size: 0.95rem;
    line-height: 1.6;
  }

  .ports__list {
    display: flex;
    flex-direction: column;
    gap: 0;
    padding: 0 28px 28px;
  }

  .ports__list li {
    display: flex;
    align-items: center;
    gap: 12px;
    color: rgba(255, 255, 255, 0.85);
    font-size: 0.95rem;
    padding: 12px 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  .ports__list li:last-child {
    border-bottom: none;
  }

  .ports__list-icon {
    font-size: 1.1rem;
    flex-shrink: 0;
    width: 28px;
    text-align: center;
  }

  @media (max-width: 768px) {
    .ports__grid { grid-template-columns: 1fr; }
    .ports { padding: 64px 0; }
  }
</style>
