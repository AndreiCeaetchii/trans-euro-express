---
---
<section class="routes" id="rute">
  <div class="routes__glow"></div>
  <div class="container">
    <div class="routes__header reveal">
      <span class="section-badge">Rute Principale</span>
      <h2 class="section-title section-title--light">Rutele Noastre</h2>
      <p class="section-subtitle section-subtitle--light">Acoperim Moldova, România și Odessa cu transport regulat și sigur</p>
    </div>

    <div class="routes__main reveal">
      <div class="routes__card routes__card--main">
        <div class="routes__card-header">
          <span class="routes__flags">🇲🇩 ↔ 🇷🇴</span>
          <h3 class="routes__card-title">Moldova — România</h3>
          <p class="routes__card-sub">Ruta principală, curse regulate</p>
        </div>
        <ul class="routes__features">
          <li>✓ Transport platformă dedicată</li>
          <li>✓ Curse regulate săptămânale</li>
          <li>✓ Asistență la vamă inclusă</li>
          <li>✓ Asigurare completă pe tot traseul</li>
          <li>✓ Ridicare și livrare door-to-door</li>
        </ul>
      </div>
    </div>

    <div class="routes__secondary">
      <div class="routes__card reveal">
        <span class="routes__flags">🇲🇩 → 🇷🇴</span>
        <h3 class="routes__card-title">Chișinău → București</h3>
        <ul class="routes__features">
          <li>✓ Durată: 8-12 ore</li>
          <li>✓ Vamă + documente incluse</li>
          <li>✓ Livrare la adresă</li>
        </ul>
      </div>
      <div class="routes__card reveal">
        <span class="routes__flags">🇲🇩 → 🇺🇦</span>
        <h3 class="routes__card-title">Moldova → Odessa</h3>
        <ul class="routes__features">
          <li>✓ Transport port Odessa</li>
          <li>✓ Asistență vamală UA</li>
          <li>✓ Vehicule din import</li>
        </ul>
      </div>
      <div class="routes__card reveal">
        <span class="routes__flags">🇷🇴 → 🇲🇩</span>
        <h3 class="routes__card-title">România → Moldova</h3>
        <ul class="routes__features">
          <li>✓ Din orice oraș din RO</li>
          <li>✓ Mașini noi și second-hand</li>
          <li>✓ Livrare în toată MD</li>
        </ul>
      </div>
    </div>
  </div>
</section>

<style>
  .routes {
    position: relative;
    background: var(--dark);
    padding: 96px 0;
    overflow: hidden;
  }

  .routes__glow {
    position: absolute;
    top: -100px;
    left: -100px;
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, rgba(240, 78, 26, 0.1) 0%, transparent 70%);
    pointer-events: none;
  }

  .routes__header {
    text-align: center;
    margin-bottom: 48px;
  }

  .routes__header .section-subtitle--light {
    margin: 0 auto;
  }

  .routes__main {
    margin-bottom: 32px;
  }

  .routes__card {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 16px;
    padding: 32px;
    transition: transform 0.3s ease, border-color 0.3s ease;
  }

  .routes__card:hover {
    transform: translateY(-4px);
    border-color: var(--orange);
  }

  .routes__card--main {
    text-align: center;
    padding: 48px 32px;
  }

  .routes__card--main .routes__features {
    max-width: 400px;
    margin: 0 auto;
  }

  .routes__card-header {
    margin-bottom: 24px;
  }

  .routes__flags {
    font-size: 2rem;
    display: block;
    margin-bottom: 12px;
  }

  .routes__card-title {
    font-family: var(--font-heading);
    font-size: 1.4rem;
    font-weight: 800;
    color: var(--white);
    margin-bottom: 4px;
  }

  .routes__card-sub {
    color: var(--gray-text);
    font-size: 0.9rem;
  }

  .routes__features {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .routes__features li {
    color: rgba(255, 255, 255, 0.75);
    font-size: 0.95rem;
  }

  .routes__secondary {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .routes__secondary .routes__flags {
    font-size: 1.5rem;
    margin-bottom: 8px;
  }

  .routes__secondary .routes__card-title {
    font-size: 1.15rem;
    margin-bottom: 16px;
  }

  @media (max-width: 768px) {
    .routes__secondary { grid-template-columns: 1fr; }
    .routes { padding: 64px 0; }
  }
</style>
